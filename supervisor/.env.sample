# MAIster supervisor — environment template (host-run daemon, ADR-023).
# Copy to supervisor/.env and fill in. supervisor/.env is gitignored.
#
# Loaded automatically on `pnpm --filter @maister/supervisor dev|start` via
# Node's --env-file-if-exists (see package.json "dev"/"start"). A shell export
# ALWAYS wins over a value here, so real secrets / CI env override the file.
#
# Scope: ONLY what the supervisor PROCESS reads. Web-tier env lives in
# web/.env.local; compose/Postgres env in the root .env. Vars tagged [shared]
# are also read by the web tier (canonical docs in the root .env.example) — set
# them here too only when the supervisor runs on a separate host.

# ---------------------------------------------------------------------------
# Daemon knobs
# ---------------------------------------------------------------------------
# Port the supervisor binds to (0.0.0.0). Default 7777.
MAISTER_SUPERVISOR_PORT=7777

# Heartbeat watcher interval in ms (orphan child detection). Default 5000.
MAISTER_HEARTBEAT_INTERVAL_MS=5000

# Grace period (ms) between SIGTERM and SIGKILL on DELETE /sessions/:id and
# during graceful shutdown of the supervisor itself. Default 5000.
MAISTER_KILL_GRACE_MS=5000

# Total time budget (ms) for graceful supervisor shutdown after SIGTERM.
# Default 15000.
MAISTER_SHUTDOWN_GRACE_MS=15000

# Optional supervisor-host binary overrides for ACP adapters. Leave unset to
# resolve from PATH: claude-agent-acp, codex-acp, gemini --acp, opencode acp,
# mimo acp.
# MAISTER_ADAPTER_BINARY_CLAUDE=/absolute/path/to/claude-agent-acp
# MAISTER_ADAPTER_BINARY_CODEX=/absolute/path/to/codex-acp
# MAISTER_ADAPTER_BINARY_GEMINI=/absolute/path/to/gemini
# MAISTER_ADAPTER_BINARY_OPENCODE=/absolute/path/to/opencode
# MAISTER_ADAPTER_BINARY_MIMO=/absolute/path/to/mimo

# Optional diagnostics cache for adapter compatibility smoke. Write it with:
# pnpm -C supervisor smoke:acp --cache <path> gemini opencode mimo
# MAISTER_ADAPTER_SMOKE_CACHE_PATH=${HOME}/.maister/adapter-smoke-cache.json

# Optional comma-separated extra env-ref NAMES surfaced (presence-only) by
# /diagnostics. Values are never returned.
# MAISTER_DIAGNOSTIC_ENV_REFS=CUSTOM_RUNNER_TOKEN,ANOTHER_PROVIDER_KEY

# [shared] Root dir under which `.maister/<slug>/runs/<id>/<step>.log` and
# `cost.jsonl` are written. Defaults to the process CWD.
# MAISTER_RUNTIME_ROOT=/repos

# [shared] M8 keep-alive + checkpoint+resume window (minutes). Read by the
# supervisor (pending-permission deferred timeout) AND the web sweeper. 30.
MAISTER_KEEPALIVE_MINUTES=30

# [shared] pino log level (web + supervisor).
# trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Provider env (optional, server-only) — NEVER log / stream / send to client
# ---------------------------------------------------------------------------
# ACP tools are configured in their own CLIs by default. Set these only when you
# want the supervisor PROCESS to provide provider env to spawned adapters.
ANTHROPIC_API_KEY=

# Override the Anthropic base URL for a compatible provider (z.ai GLM,
# OpenRouter, anyscale). Per-executor envs in maister.yaml take precedence —
# this is a process-wide default.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=

# Model discovery only (ADR-075): the supervisor's provider_api source lists
# models for plain `openai`-provider codex runner drafts; unset => "skipped".
OPENAI_API_KEY=

# Other providers resolve their key NAME from the runner's provider config,
# e.g. GEMINI_API_KEY / GOOGLE_API_KEY / DASHSCOPE_API_KEY — add as needed.

# ---------------------------------------------------------------------------
# MCP server secret refs
# ---------------------------------------------------------------------------
# A platform/project MCP server stores secrets as `env:NAME` references only;
# the supervisor resolves the VALUE here, by NAME, at adapter spawn (stdio env
# var for stdio servers, header value for sse/http). Add one line per NAME your
# registered MCP servers reference. Examples:
CONTEXT7_API_KEY=
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# CCR (Claude Code Router) — only with `router: ccr` executors. [shared]
# ---------------------------------------------------------------------------
# Full docs + the Docker bind-mount var live in the root .env.example. On a
# separate supervisor host, set at least the auth token here:
# MAISTER_CCR_AUTH_TOKEN=
# MAISTER_CCR_CONFIG_PATH=
