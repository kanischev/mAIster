{
  "name": "maister-web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:integration": "vitest run --project integration --passWithNoTests",
    "test:watch": "vitest --project unit",
    "test:e2e": "playwright test --pass-with-no-tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:seed": "tsx --import ./scripts/_register-shim.mjs lib/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "install-flow": "tsx --import ./scripts/_register-shim.mjs scripts/install-flow.ts",
    "run-flow": "tsx --import ./scripts/_register-shim.mjs scripts/run-flow.ts"
  },
  "dependencies": {
    "@heroui/react": "3.0.4",
    "@heroui/styles": "3.0.4",
    "better-sqlite3": "^12.10.0",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.36.4",
    "intl-messageformat": "10.7.16",
    "mustache": "^4.2.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "^0.0.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.8",
    "@eslint/eslintrc": "3.3.1",
    "@eslint/js": "9.25.1",
    "@next/eslint-plugin-next": "16.2.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "4.1.11",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mustache": "^4.2.6",
    "@types/node": "20.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.34.1",
    "@typescript-eslint/parser": "8.34.1",
    "@vitest/ui": "^2.1.9",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.1",
    "eslint": "9.25.1",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.5.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-unused-imports": "4.1.4",
    "globals": "16.0.0",
    "pino-pretty": "^11.3.0",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
    "tailwind-variants": "3.2.2",
    "tailwindcss": "4.1.11",
    "testcontainers": "^10.28.0",
    "tsx": "^4.22.3",
    "typescript": "5.6.3",
    "vitest": "^2.1.9"
  }
}
