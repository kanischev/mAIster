# MAIster web — environment template.
# Copy to .env.local and fill in. Never commit .env.local.
#
#   cp .env.sample .env.local
#
# Next.js loads .env.local automatically from this directory when running
# `pnpm dev`. Keys here mirror the ones read by web/ code; the root
# .env.example covers the supervisor + Docker stack as well.

# ---------------------------------------------------------------------------
# Authentication (Auth.js v5)
# ---------------------------------------------------------------------------
# REQUIRED. Used to sign/verify the session JWT. Generate with:
#   openssl rand -base64 33   (or: npx auth secret)
# Must match across web replicas. Never log, never expose.
AUTH_SECRET=

# Optional. Canonical origin, e.g. https://maister.example.com. Auth.js
# trusts the request host by default — only set if a proxy rewrites Host
# in a way that breaks callback URLs. Leave blank in dev.
AUTH_URL=

# Dev seed for `pnpm db:seed` — creates this admin user if absent.
# Change the password before any shared use.
SEED_ADMIN_EMAIL=admin@maister.local
SEED_ADMIN_PASSWORD=maister-admin

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Postgres via docker compose (host port 5432). For SQLite ultra-light dev:
#   DB_URL=file:./dev.db
DB_URL=postgres://maister:maister@localhost:5432/maister

# Optional. Postgres pool ceiling per web process. Default 10.
# MAISTER_DB_POOL_MAX=10

# ---------------------------------------------------------------------------
# Supervisor daemon
# ---------------------------------------------------------------------------
# Web tier → supervisor. Defaults to http://localhost:7777 if unset.
# MAISTER_SUPERVISOR_URL=http://localhost:7777

# ---------------------------------------------------------------------------
# Runtime + worktree roots
# ---------------------------------------------------------------------------
# Root under which `.maister/<slug>/runs/<id>/<step>.log` is written.
# Defaults to the web process cwd.
# MAISTER_RUNTIME_ROOT=

# Root under which `git worktree add` creates run worktrees.
# Defaults to ${HOME}/.maister.
# MAISTER_WORKTREE_ROOT=

# ---------------------------------------------------------------------------
# Scheduler + keep-alive (see ../CLAUDE.md §8 and root .env.example)
# ---------------------------------------------------------------------------
# Global concurrency cap across all projects. Default 3 (POC).
MAISTER_MAX_CONCURRENT_RUNS=3

# NeedsInput live window (minutes). Default 30.
# MAISTER_KEEPALIVE_MINUTES=30

# Keep-alive sweeper tick (seconds). Default 30.
# MAISTER_KEEPALIVE_SWEEP_INTERVAL_SECONDS=30

# NeedsInputIdle → Abandoned TTL (hours). Default 24.
# MAISTER_NEEDSINPUTIDLE_TTL_HOURS=24

# Resume-prompt watchdog (seconds). Default 60.
# MAISTER_RESUME_PROMPT_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# pino level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=debug
