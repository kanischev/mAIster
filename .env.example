# MAIster — environment template.
# Copy to .env and fill in. Do NOT commit .env.

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=maister

# Container image tag. Override per environment.
# In dev (compose.yml + compose.override.yml) defaults to "maister/app:dev".
# In production (compose.production.yml) MAISTER_IMAGE is required and must
# point to a pinned, registry-hosted tag, e.g. registry.example.com/maister/app:1.2.3
MAISTER_IMAGE=maister/app:dev

# Host path mounted at /repos inside the container — git worktree targets
# the parent repos here. Defaults to ~/.maister (compose resolves ${HOME}).
# Override per environment (CI, prod, multi-host setups).
MAISTER_REPOS_HOST_PATH=${HOME}/.maister

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV=development

# POC concurrency cap. Do NOT raise above 1 without a real reason.
MAISTER_MAX_CONCURRENT_RUNS=1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=maister
POSTGRES_PASSWORD=maister
POSTGRES_DB=maister

# Postgres in dev. For SQLite ultra-light mode: DB_URL=file:./dev.db
DB_URL=postgres://maister:maister@postgres:5432/maister

# ---------------------------------------------------------------------------
# Headless Claude Code (Anthropic API key, server-only)
# ---------------------------------------------------------------------------
# NEVER log this, NEVER stream via SSE, NEVER send to client.
ANTHROPIC_API_KEY=
