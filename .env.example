# MAIster — environment template.
# Copy to .env and fill in. Do NOT commit .env.

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=maister

# Container image tag. Override per environment.
# In dev (compose.yml + compose.override.yml) defaults to "maister/app:dev".
# In production (compose.production.yml) MAISTER_IMAGE is required and must
# point to a pinned, registry-hosted tag, e.g. registry.example.com/maister/app:1.2.3
MAISTER_IMAGE=maister/app:dev

# Host path mounted at /repos inside the container — git worktree targets
# the parent repos here. Defaults to ~/.maister (compose resolves ${HOME}).
# Override per environment (CI, prod, multi-host setups).
MAISTER_REPOS_HOST_PATH=${HOME}/.maister

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV=development

# POC concurrency cap. Do NOT raise above 1 without a real reason.
MAISTER_MAX_CONCURRENT_RUNS=1

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=maister
POSTGRES_PASSWORD=maister
POSTGRES_DB=maister

# Postgres in dev. For SQLite ultra-light mode: DB_URL=file:./dev.db
DB_URL=postgres://maister:maister@postgres:5432/maister

# ---------------------------------------------------------------------------
# Headless Claude Code (Anthropic API key, server-only)
# ---------------------------------------------------------------------------
# NEVER log this, NEVER stream via SSE, NEVER send to client.
ANTHROPIC_API_KEY=

# Optional: override the Anthropic base URL when routing through a
# compatible provider (z.ai GLM, OpenRouter, anyscale). Per-executor envs in
# `maister.yaml` take precedence — these are process-wide defaults.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Supervisor daemon (separate Node process; M3+)
# ---------------------------------------------------------------------------
# Web tier → supervisor. In compose this resolves to http://supervisor:7777.
# Default in `web/lib/supervisor-client.ts` is http://localhost:7777.
MAISTER_SUPERVISOR_URL=http://supervisor:7777

# Port the supervisor binds to (0.0.0.0). Default 7777.
MAISTER_SUPERVISOR_PORT=7777

# Root directory under which `.maister/<slug>/runs/<id>/<step>.log` and
# `cost.jsonl` are written. Defaults to the supervisor's CWD.
# MAISTER_RUNTIME_ROOT=/repos

# Heartbeat watcher interval in ms (orphan child detection). Default 5000.
MAISTER_HEARTBEAT_INTERVAL_MS=5000

# Grace period (ms) between SIGTERM and SIGKILL on DELETE /sessions/:id and
# during graceful shutdown of the supervisor itself. Default 5000.
MAISTER_KILL_GRACE_MS=5000

# Total time budget (ms) for graceful supervisor shutdown after SIGTERM.
# Default 15000.
MAISTER_SHUTDOWN_GRACE_MS=15000

# Reserved for M8 (keep-alive + checkpoint+resume). Window in minutes during
# which a NeedsInput session stays live; each user activity extends by the
# same window. Default 30. Surfaced now to keep ops configuration stable.
MAISTER_KEEPALIVE_MINUTES=30

# ---------------------------------------------------------------------------
# CCR (Claude Code Router) — only used when an executor has `router: ccr`
# in maister.yaml. CCR's own config file (host, port, providers, keys)
# lives in ~/.claude-code-router/config.json and is user-managed; MAIster
# reads it but never writes it.
# ---------------------------------------------------------------------------
# Token sent into the spawned adapter as ANTHROPIC_AUTH_TOKEN when
# executor.env.ANTHROPIC_AUTH_TOKEN is not set. Required for router=ccr
# executors that do not pin the token per-executor in maister.yaml.
# CCR currently accepts any non-empty value (routing is config-driven, not
# auth-driven) but the adapter refuses to start without one.
MAISTER_CCR_AUTH_TOKEN=

# CCR config file location INSIDE the container/process. In Docker the
# default is `/app/.ccr/config.json` (the bind-mount target — see
# MAISTER_CCR_CONFIG_HOST_PATH below). Outside Docker, the supervisor
# falls back to ~/.claude-code-router/config.json. Override for tests
# or non-standard layouts.
# MAISTER_CCR_CONFIG_PATH=

# Host path bind-mounted at /app/.ccr inside the supervisor container
# (read-only). Defaults to ~/.claude-code-router on the host — the
# standard CCR location. Override to point at a secret-mount path in
# hardened deployments. If the host path does not exist, Docker
# silently creates an empty directory and the supervisor surfaces 503
# EXECUTOR_UNAVAILABLE on first router=ccr session (that's the
# documented contract — see docs/system-analytics/executors.md#ccr-setup).
# MAISTER_CCR_CONFIG_HOST_PATH=${HOME}/.claude-code-router

# pino log level for both web (`pino` per-module) and supervisor.
# Options: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=debug
