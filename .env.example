# MAIster — environment template.
# Copy to .env and fill in. Do NOT commit .env.

# ---------------------------------------------------------------------------
# Docker Compose
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=maister

# Container image tag. Override per environment.
# compose.yml containerizes Postgres only in dev; web and supervisor run on
# the host with pnpm.
# In production (compose.production.yml) MAISTER_IMAGE is required and must
# point to a pinned, registry-hosted tag, e.g. registry.example.com/maister/app:1.2.3
MAISTER_IMAGE=maister/app:dev

# Host path mounted at /repos inside the container — git worktree targets
# the parent repos here. Defaults to ~/.maister (compose resolves ${HOME}).
# Override per environment (CI, prod, multi-host setups).
MAISTER_REPOS_HOST_PATH=${HOME}/.maister

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV=development

# POC concurrency cap. Do NOT raise above 1 without a real reason.
MAISTER_MAX_CONCURRENT_RUNS=1

# M24 scheduler service budgets. These are separate from the Flow run cap:
# command and agent_tick work must not evict delivery runs.
MAISTER_MAX_CONCURRENT_AGENTS=1
MAISTER_MAX_CONCURRENT_COMMANDS=2

# Flow package trust policy (M10, ADR-021). Comma-separated source-URL
# prefixes that are trusted by policy: a Flow package installed from a matching
# git source is auto-enabled, while any other source stays untrusted until an
# explicit per-(project, revision) trust confirmation in the UI. local/file://
# sources are always trusted by policy regardless of this list. Empty = only
# local sources are trusted by policy.
#   e.g. MAISTER_TRUSTED_FLOW_SOURCE_PREFIXES=github.com/my-org/,gitlab.com/my-org/
MAISTER_TRUSTED_FLOW_SOURCE_PREFIXES=

# Capability import trust policy (M14, ADR-042). Comma-separated source-URL
# prefixes whose capability_imports[] packages are trusted by policy
# (auto-trusted on install; their setup.sh may run without an explicit
# confirm). Mirrors MAISTER_TRUSTED_FLOW_SOURCE_PREFIXES exactly: local/file://
# sources are always trusted by policy; any other source stays untrusted until
# an operator confirms via POST /api/projects/{slug}/capabilities/{refId}/trust.
# `trust: explicit` on an import forces the confirm even for policy-trusted
# sources. Empty = only local sources are trusted by policy. Read by the
# host-run web tier (web/lib/capabilities/import.ts:resolveCapabilityTrust).
#   e.g. MAISTER_TRUSTED_CAPABILITY_SOURCE_PREFIXES=github.com/my-org/
MAISTER_TRUSTED_CAPABILITY_SOURCE_PREFIXES=

# M22 workbench file viewer (ADR-053): max size (bytes) of a single git-tracked
# blob the read-only file viewer serves. A larger tracked file returns a 413
# "too-large" marker; the bytes are never sent. Default 524288 (512 KiB).
MAISTER_WORKBENCH_MAX_FILE_BYTES=524288

# M26 structured node output (ADR-063): max raw size (bytes) of a node's
# structured-output payload (agent `json maister:output` sentinel block or the
# cli MAISTER_OUTPUT_FILE contents) before parse/validate at the post-action
# seam; exceeding it fails the attempt with CONFIG. Host env only (ADR-023 —
# web runs on the host; never a compose var). Default 262144 (256 KiB).
# MAISTER_NODE_OUTPUT_MAX_BYTES=262144

# M29 observatory harness adequacy (ADR-072): minimum terminal gate executions
# in the lookback window before the never-fired heuristic may flag a declared
# gate as "never fired". Host env only (ADR-023). Default 10.
# MAISTER_HARNESS_NEVER_FIRED_MIN=10

# ---------------------------------------------------------------------------
# Authentication (NextAuth / Auth.js v5) — web tier only
# ---------------------------------------------------------------------------
# REQUIRED. Secret used to sign/verify the session JWT. Generate with:
#   openssl rand -base64 33   (or: npx auth secret)
# Must be identical across all web replicas; never log it, never expose it.
AUTH_SECRET=

# Optional. Canonical origin of the app, e.g. https://maister.example.com.
# Auth.js trusts the request host (trustHost) so this is only needed if the
# proxy rewrites Host in a way that breaks callback URLs. Leave blank in dev.
AUTH_URL=

# Optional dev seed. `pnpm db:seed` creates this admin user if absent (first
# user is always role=admin). Change the password before any shared use.
SEED_ADMIN_EMAIL=admin@maister.local
SEED_ADMIN_PASSWORD=maister-admin

# Length of admin-provisioned auto-generated one-time temp passwords (clamped
# to a minimum of 12). Governs GENERATED passwords only — admin-typed passwords
# keep the 12-character minimum. Read server-side; never logged. Default 12.
MAISTER_TEMP_PASSWORD_LENGTH=12

# i18n: the UI locale (en|ru) is stored in the NEXT_LOCALE cookie, set by the
# in-app language toggle and falling back to the Accept-Language header. No
# env var is required; documented here so ops knows the cookie name.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
POSTGRES_USER=maister
POSTGRES_PASSWORD=maister
POSTGRES_DB=maister

# Postgres in dev (containerized; web/supervisor run on the host — see ADR-023).
# For SQLite ultra-light mode: DB_URL=file:./dev.db
DB_URL=postgres://maister:maister@localhost:5432/maister

# ---------------------------------------------------------------------------
# Optional model discovery / legacy provider env (server-only)
# ---------------------------------------------------------------------------
# ACP tools are configured in their own CLIs by default. Keep these unset unless
# you intentionally want the supervisor process to provide provider env.
# NEVER log these, NEVER stream via SSE, NEVER send to client.
ANTHROPIC_API_KEY=

# Optional: override the Anthropic base URL when routing through a
# compatible provider (z.ai GLM, OpenRouter, anyscale). Per-executor envs in
# `maister.yaml` take precedence — these are process-wide defaults.
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=

# Optional: model discovery only (ADR-075). The supervisor's provider_api
# source lists models for plain `openai`-provider codex runner drafts; unset →
# that source reports status "skipped". Same secrecy rules as above.
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Supervisor daemon (separate Node process; M3+)
# ---------------------------------------------------------------------------
# Web tier → supervisor. Both run on the host (see ADR-023), so this is
# loopback. Matches the default in `web/lib/supervisor-client.ts`.
MAISTER_SUPERVISOR_URL=http://localhost:7777

# Port the supervisor binds to (0.0.0.0). Default 7777.
MAISTER_SUPERVISOR_PORT=7777

# Root directory under which `.maister/<slug>/runs/<id>/<step>.log` and
# `cost.jsonl` are written. Defaults to the supervisor's CWD.
# MAISTER_RUNTIME_ROOT=/repos

# Optional supervisor-host binary overrides for ACP adapters. Leave unset to
# resolve from PATH: claude-agent-acp, codex-acp, gemini --acp, opencode acp,
# mimo acp.
# MAISTER_ADAPTER_BINARY_CLAUDE=/absolute/path/to/claude-agent-acp
# MAISTER_ADAPTER_BINARY_CODEX=/absolute/path/to/codex-acp
# MAISTER_ADAPTER_BINARY_GEMINI=/absolute/path/to/gemini
# MAISTER_ADAPTER_BINARY_OPENCODE=/absolute/path/to/opencode
# MAISTER_ADAPTER_BINARY_MIMO=/absolute/path/to/mimo

# Optional diagnostics cache for adapter compatibility smoke. Write it with:
# pnpm -C supervisor smoke:acp --cache <path> gemini opencode mimo
# MAISTER_ADAPTER_SMOKE_CACHE_PATH=${HOME}/.maister/adapter-smoke-cache.json

# Optional comma-separated extra env-ref NAMES shown by /diagnostics.
# Values are never returned.
# MAISTER_DIAGNOSTIC_ENV_REFS=CUSTOM_RUNNER_TOKEN,ANOTHER_PROVIDER_KEY

# Heartbeat watcher interval in ms (orphan child detection). Default 5000.
MAISTER_HEARTBEAT_INTERVAL_MS=5000

# Grace period (ms) between SIGTERM and SIGKILL on DELETE /sessions/:id and
# during graceful shutdown of the supervisor itself. Default 5000.
MAISTER_KILL_GRACE_MS=5000

# Total time budget (ms) for graceful supervisor shutdown after SIGTERM.
# Default 15000.
MAISTER_SHUTDOWN_GRACE_MS=15000

# M8 keep-alive + checkpoint+resume window (minutes). A NeedsInput
# session stays live for this window; each web-console activity (open
# run page, focus, debounced keystroke/pointer-down, or periodic
# heartbeat) extends the window by the same amount. On expiry the
# keepalive sweeper checkpoints the agent into NeedsInputIdle. Read by
# BOTH the supervisor (pending-permission deferred timeout) AND the
# web tier (sweeper + activity bump + useActivityPing heartbeat at
# MAISTER_KEEPALIVE_MINUTES/2). Default 30.
MAISTER_KEEPALIVE_MINUTES=30

# M8 sweeper tick frequency (seconds). The web-side keep-alive sweeper
# polls the DB every interval to (a) checkpoint NeedsInput rows whose
# keepalive_until has expired and (b) flip NeedsInputIdle rows whose
# checkpoint_at + NEEDSINPUTIDLE_TTL_HOURS has expired into Abandoned.
# Lower values reduce idle-window jitter; higher values reduce DB load.
# Default 30.
MAISTER_KEEPALIVE_SWEEP_INTERVAL_SECONDS=30

# M8 NeedsInputIdle abandonment TTL (hours). After this many hours
# without an operator response, sweeper pass 2 transitions the run to
# Abandoned and closes any open hitl_requests row. Default 24.
MAISTER_NEEDSINPUTIDLE_TTL_HOURS=24

# M8 resume-prompt watchdog timeout (seconds). When a NeedsInputIdle
# run is respawned via --resume, the runner-agent expects a fresh
# session.permission_request within this window; on timeout the run
# transitions to Crashed via crashResumedRun. Surfaced for ops tuning;
# enforcement landing post-M8. Default 60.
MAISTER_RESUME_PROMPT_TIMEOUT_SECONDS=60

# M19 reconcile sweeper tick frequency (seconds). The periodic reconcile
# sweep reconciles stranded `Running` runs against the supervisor's live
# session set + `git worktree list`: worktree-gone / agent-session-gone
# past grace / mid-step cli → Crashed; live session → re-attach; session-less
# gate → re-dispatch. Floor 1. Default 60.
MAISTER_RECONCILE_SWEEP_INTERVAL_SECONDS=60

# M19 reconcile grace window (seconds). A `Running` agent run with no live
# supervisor session is NOT crashed while its resume_started_at or latest
# node attempt is within this window — protects launches/recovers still
# spinning up their ACP session from a false-positive crash. Floor 1. Default 90.
MAISTER_RECONCILE_GRACE_SECONDS=90

# M19 graceful GC (preserve-then-prune). The background GC sweeper preserves
# every terminal (Abandoned/Done) workspace's work into a
# maister/archive/<runId> branch, then prunes the worktree; it also deletes
# Removed flow revisions older than the age below.

# How long after a run's endedAt its Abandoned/Done workspace + a Removed flow
# revision become GC-eligible (days). Floor 1. Default 14.
MAISTER_GC_AGE_DAYS=14

# Pre-removal warning window (days) used by the TTL color ramp in the UI.
# Floor 1. Default 2.
MAISTER_GC_WARNING_DAYS=2

# Background GC sweeper tick frequency (seconds). Floor 1. Default 3600.
MAISTER_GC_SWEEP_INTERVAL_SECONDS=3600

# When "true" (exact value), GC preserve also pushes the
# maister/archive/<runId> branch to the run's git remote. Default false; the
# local archive ref always preserves the work even without a push.
MAISTER_GC_ARCHIVE_PUSH=false

# Server-only secret guarding GET/POST /api/cron/gc (header
# X-Maister-Cron-Token). M24 also uses the same secret for
# GET/POST /api/cron/tick. EMPTY disables both routes → 503 (cron disabled).
# Never logged, never streamed; do NOT commit a real value.
MAISTER_CRON_TOKEN=

# M24 unified scheduler tick. External cron should call /api/cron/tick in
# production. This fallback timer is for single-box deployments only and starts
# only when explicitly enabled.
MAISTER_SCHEDULER_TIMER_ENABLED=false
MAISTER_SCHEDULER_TICK_INTERVAL_SECONDS=60
MAISTER_SCHEDULER_ATTEMPT_TIMEOUT_SECONDS=300
MAISTER_SCHEDULER_AGENT_TICK_MAX_FAILURES=3

# Outbound webhooks (ADR-076). The webhook_delivery scheduler job (web tier)
# fans out + drains deliveries each tick; the supervisor needs none of these.
# Max deliveries/events claimed per drain tick (bounds memory + HTTP concurrency).
MAISTER_WEBHOOK_DELIVERY_BATCH=20
# Per-attempt HTTP timeout (ms) for both the drain path and the test-ping route.
MAISTER_WEBHOOK_TIMEOUT_MS=10000
# Terminal-dead threshold: a delivery hitting this attempt_count becomes `dead`.
MAISTER_WEBHOOK_MAX_ATTEMPTS=8
# Destination egress-policy allowlist: comma-separated EXACT hosts exempt from
# the SSRF block (loopback/private/link-local/metadata/multicast/unspecified),
# e.g. a local consumer in dev. Unset = no exemptions.
# MAISTER_WEBHOOK_ALLOW_HOSTS=127.0.0.1

# ---------------------------------------------------------------------------
# Promotion (M18 — branch targeting + manual promotion)
# ---------------------------------------------------------------------------
# Stale-`claiming` promotion-claim reclaim window (seconds). A
# workspaces.promotion_state='claiming' claim older than this is reclaimable by
# the next promote attempt (crash recovery), which re-mints promotion_attempt_id.
# Always optional with a default; read by the web tier. Default 300.
MAISTER_PROMOTION_CLAIM_TIMEOUT_SECONDS=300

# Per-provider PR-mode promotion host auth — server-only, NEVER logged, NEVER
# streamed via SSE. Needed ONLY when a run promotes via `pull_request`;
# `local_merge` promotion needs none of these. Per the run's detected provider:
#   github   → `gh` CLI on PATH + GH_TOKEN (or `gh auth login`)
#   gitlab   → `glab` CLI on PATH + GITLAB_TOKEN (or `glab auth login`)
#   gitea    → GITEA_TOKEN (Gitea-compatible REST adapter; no CLI)
#   gitverse → GITVERSE_TOKEN (same Gitea-compatible REST adapter)
# All providers also need a host git push credential helper for the remote.
# The default compose does NOT provision these (host-operator concern — ADR-023).
# GH_TOKEN=
# GITLAB_TOKEN=
# GITEA_TOKEN=
# GITVERSE_TOKEN=

# ---------------------------------------------------------------------------
# CCR (Claude Code Router) — only used when an executor has `router: ccr`
# in maister.yaml. CCR's own config file (host, port, providers, keys)
# lives in ~/.claude-code-router/config.json and is user-managed; MAIster
# reads it but never writes it.
# ---------------------------------------------------------------------------
# Token sent into the spawned adapter as ANTHROPIC_AUTH_TOKEN when
# executor.env.ANTHROPIC_AUTH_TOKEN is not set. Required for router=ccr
# executors that do not pin the token per-executor in maister.yaml.
# CCR currently accepts any non-empty value (routing is config-driven, not
# auth-driven) but the adapter refuses to start without one.
MAISTER_CCR_AUTH_TOKEN=

# CCR config file location INSIDE the container/process. In Docker the
# default is `/app/.ccr/config.json` (the bind-mount target — see
# MAISTER_CCR_CONFIG_HOST_PATH below). Outside Docker, the supervisor
# falls back to ~/.claude-code-router/config.json. Override for tests
# or non-standard layouts.
# MAISTER_CCR_CONFIG_PATH=

# Host path bind-mounted at /app/.ccr inside the supervisor container
# (read-only). Defaults to ~/.claude-code-router on the host — the
# standard CCR location. Override to point at a secret-mount path in
# hardened deployments. If the host path does not exist, Docker
# silently creates an empty directory and the supervisor surfaces 503
# EXECUTOR_UNAVAILABLE on first router=ccr session (that's the
# documented contract — see docs/system-analytics/executors.md#ccr-setup).
# MAISTER_CCR_CONFIG_HOST_PATH=${HOME}/.claude-code-router

# pino log level for both web (`pino` per-module) and supervisor.
# Options: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# MCP facade (mcp/ package — M16, Implemented)
# Only needed when running the standalone MCP server against a MAIster instance.
# ---------------------------------------------------------------------------
# Base URL of the MAIster REST API the MCP facade wraps.
# Use the external HTTPS address in production.
MAISTER_API_BASE_URL=http://localhost:3000

# Project token for the stdio (local-only) transport.
# IGNORED under the Streamable-HTTP transport, which requires a per-request
# inbound bearer header instead. Not read by the web or supervisor processes.
# Do NOT commit a real token value here.
MAISTER_PROJECT_TOKEN=

# Transport selection for the MCP facade. Default (unset) = Streamable-HTTP
# (remote; per-request inbound bearer, no ambient token). Set to `stdio` (or
# pass --stdio) for the local stdio transport that reads MAISTER_PROJECT_TOKEN.
MCP_TRANSPORT=
# HTTP bind port for the Streamable-HTTP transport (default 3001). Unused under stdio.
MCP_PORT=3001

# --- Package discovery (ADR-087) ---
# Staleness window (hours) for the startup package-source discovery sweep:
# enabled package_sources with last_checked_at older than this are refreshed
# at web boot (git ls-remote + manifest scan). The manual Refresh button
# ignores the window. Integer >= 1. Default 24.
MAISTER_PACKAGE_DISCOVERY_STALE_HOURS=24
