# MAIster systemd EnvironmentFile.
# Copy to /etc/maister/maister.env, then: chown maister:maister && chmod 600.
# Shared by maister-supervisor.service and maister-web.service.
# Full variable reference: docs/configuration.md.

NODE_ENV=production
LOG_LEVEL=info

# Repo checkout dir. Supervisor AND web resolve `.maister/` from here, so both
# units MUST use this same path (co-located shared filesystem — see ADR-023).
MAISTER_RUNTIME_ROOT=/opt/maister

# Repo + worktree roots (optional; ADR-025). Default to the maister user's home
# (~/.maister/repos, ~/.maister/worktrees). Set these to place clones and run
# worktrees on a specific volume. MAISTER_WORKTREE_ROOT (singular) is a
# deprecated fallback for MAISTER_WORKTREES_ROOT.
# MAISTER_REPOS_ROOT=/opt/maister/repos
# MAISTER_WORKTREES_ROOT=/opt/maister/worktrees

# --- Database: Postgres in Docker, published on loopback (see compose.yml) ---
DB_URL=postgres://maister:maister@localhost:5432/maister
POSTGRES_USER=maister
POSTGRES_PASSWORD=change-me
POSTGRES_DB=maister

# --- Web <-> supervisor: loopback only. NEVER expose :7777 publicly. ---
MAISTER_SUPERVISOR_URL=http://localhost:7777
MAISTER_SUPERVISOR_PORT=7777

# --- Auth.js (web). Generate the secret with: openssl rand -base64 32 ---
AUTH_SECRET=
AUTH_URL=https://maister.example.com

# --- Agent credentials (headless; env-router model — NO interactive login).
#     The supervisor passes process env to spawned agents, so keys set here
#     reach claude-agent-acp / codex-acp. Per-executor env in maister.yaml
#     overrides these process-wide defaults. ---
ANTHROPIC_API_KEY=
# Optional Anthropic-compatible provider (z.ai GLM, OpenRouter, ...):
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ANTHROPIC_AUTH_TOKEN=
# For codex executors (codex-acp bundles @openai/codex):
# OPENAI_API_KEY=

# --- Concurrency + keep-alive (defaults; see docs/configuration.md) ---
MAISTER_MAX_CONCURRENT_RUNS=3
MAISTER_KEEPALIVE_MINUTES=30

# --- Outbound webhooks (ADR-076; web tier only — defaults; see docs/configuration.md) ---
# Max deliveries/events claimed per webhook_delivery drain tick.
MAISTER_WEBHOOK_DELIVERY_BATCH=20
# Per-attempt HTTP timeout (ms) for the drain path and the test-ping route.
MAISTER_WEBHOOK_TIMEOUT_MS=10000
# Terminal-dead threshold: a delivery hitting this attempt_count becomes `dead`.
MAISTER_WEBHOOK_MAX_ATTEMPTS=8
# Destination egress-policy allowlist: comma-separated EXACT hosts exempt from
# the SSRF block (loopback/private/link-local/metadata/multicast/unspecified),
# e.g. a local consumer. Unset = no exemptions.
# MAISTER_WEBHOOK_ALLOW_HOSTS=127.0.0.1
